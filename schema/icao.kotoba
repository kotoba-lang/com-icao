// Icao clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace icao {

    entity Declaration {
        id: string @unique
        declarantId: string
        type: string
        hsCode: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Shipment {
        id: string @unique
        declarationId: string
        carrier: string
        origin: string
        destination: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Manifest {
        id: string @unique
        shipmentId: string
        vessel: string
        containerCount: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Tariff {
        id: string @unique
        hsCode: string
        rate: float
        jurisdiction: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Permit {
        id: string @unique
        declarationId: string
        type: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Party {
        id: string @unique
        name: string
        role: string
        taxId: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
